APP_NAME="Université Toumai"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
GESTION_TIME_FORMAT=H:i

# School Configuration
SCHOOL_CODE=ETB
SCHOOL_NAME="Université TOUAMI"
SCHOOL_ADDRESS="Ndjaména, Tchad"
SCHOOL_PHONE="+235 00 00 00 00"
SCHOOL_EMAIL="contact@toumai.mr"

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=toumai_db
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# School Configuration
SCHOOL_NAME="Université TOUMAI"
SCHOOL_ADDRESS=""
SCHOOL_PHONE=""
SCHOOL_EMAIL=""

# Academic Year Configuration
# Month when the academic year starts (1-12): 10=October, 9=September, 8=August
ACADEMIC_YEAR_START_MONTH=10

# Trimester System (Default configuration for Chadian schools - October start)
TRIMESTRE_1_START_MONTH=10
TRIMESTRE_1_START_DAY=1
TRIMESTRE_1_END_MONTH=12
TRIMESTRE_1_END_DAY=31

TRIMESTRE_2_START_MONTH=1
TRIMESTRE_2_START_DAY=1
TRIMESTRE_2_END_MONTH=4
TRIMESTRE_2_END_DAY=30

TRIMESTRE_3_START_MONTH=5
TRIMESTRE_3_START_DAY=1
TRIMESTRE_3_END_MONTH=9
TRIMESTRE_3_END_DAY=30

# Alternative: Semester System (set USE_SEMESTERS=true to enable)
USE_SEMESTERS=false
SEMESTER_1_START_MONTH=10
SEMESTER_1_START_DAY=1
SEMESTER_1_END_MONTH=2
SEMESTER_1_END_DAY=28

SEMESTER_2_START_MONTH=3
SEMESTER_2_START_DAY=1
SEMESTER_2_END_MONTH=7
SEMESTER_2_END_DAY=31


SCHOOL_CODE=YSC

# Demo credentials for panel logins (used by Filament login form demo)
# Set DEMO_PANEL to force which role's demo credentials are shown: admin, staff, teacher
DEMO_PANEL=
DEMO_ADMIN_EMAIL=admin@toumai.com
DEMO_ADMIN_PASSWORD=admin123
DEMO_STAFF_EMAIL=gestionnaire@toumai.com
DEMO_STAFF_PASSWORD=gestionnaire123
DEMO_TEACHER_EMAIL=cherif@toumai.com
DEMO_TEACHER_PASSWORD=enseignant123
